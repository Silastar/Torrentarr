# Media root inside container
MEDIA_ROOT=/MEDIA

# Output root inside container
OUTPUT_ROOT=/TORRENTS

# Torrent announce URL
ANNOUNCE=https://your.tracker/announce

# Default release group
DEFAULT_TEAM=YOURGROUP

# Preferred tag when multiple languages
PREFERRED_LANG_MULTI=MULTI

# Torrent options
PRIVATE_FLAG=1
SHOW_PROGRESS=1
TORRENT_THREADS=4
TORRENT_COMMENT=Created with torrent-creator

# Behavior
SKIP_EXISTING=1
DRY_RUN=0

# Staging
USE_STAGING=0
STAGING_DIR=/STAGING
STAGING_MIN_FREE_GB=20

# Radarr
RADARR_URL=http://radarr:7878
RADARR_API_KEY=CHANGE_ME

# Radarr 4K
RADARR_4K_URL=http://radarr4k:7878
RADARR_4K_API_KEY=CHANGE_ME

# Sonarr
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=CHANGE_ME

# Sonarr 4K
SONARR_4K_URL=http://sonarr4k:8989
SONARR_4K_API_KEY=CHANGE_ME
